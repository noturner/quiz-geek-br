<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppButtonStyle" parent="Widget.AppCompat.Button">
        <!-- Customize your button style here. -->
        <item name="android:background">@drawable/button_background
        </item> <!-- Background do botão -->
        <item name="android:textColor">@color/black</item> <!-- Cor do texto do botão -->
        <item name="android:textAllCaps">false</item> <!-- Não transformar o texto em caixa alta -->
        <item name="android:paddingVertical">12dp</item> <!-- Espaçamento vertical interno -->
        <item name="android:paddingHorizontal">24dp</item> <!-- Espaçamento horizontal interno -->
    </style>
</resources>
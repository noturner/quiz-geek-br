    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar" > // <!-- pode dar erro -->
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/black</item> <!-- Cor de fundo da janela -->
        <item name="android:textColorPrimary">@color/black</item> <!-- Cor do texto principal -->
        <item name="android:textColorSecondary">@color/black</item> <!-- Cor do texto secundário -->
        <item name="android:buttonStyle">@style/AppButtonStyle</item> <!-- Estilo dos botões -->
        <item name="android:windowActionBarOverlay">true</item>
        <item name="windowActionBarOverlay">true</item>
    </style>

    <style name="AppButtonStyle" parent="Widget.AppCompat.Button">
        <!-- Customize your button style here. -->
        <item name="android:background">@drawable/button_background</item> <!-- Background do botão -->
        <item name="android:textColor">@color/black</item> <!-- Cor do texto do botão -->
        <item name="android:textAllCaps">false</item> <!-- Não transformar o texto em caixa alta -->
        <item name="android:paddingVertical" tools:targetApi="o">12dp</item> <!-- Espaçamento vertical interno -->
        <item name="android:paddingHorizontal" tools:targetApi="o">24dp</item> <!-- Espaçamento horizontal interno -->
    </style>
